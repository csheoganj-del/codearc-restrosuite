# ============================================================
# RestoSuite — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's REST/Realtime API base URL
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Public anon key — safe to expose in browser bundles
SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — SERVER-SIDE / Edge Functions ONLY.
# Has full DB access and bypasses RLS. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Edge Functions ───────────────────────────────────────────
# JWT secret used to sign/verify tenant session tokens.
# Generate with: openssl rand -hex 64
SUPERADMIN_SESSION_SECRET=<random-64-byte-hex-secret>

# Also set this as a Supabase Edge Function secret:
# supabase secrets set SUPERADMIN_SESSION_SECRET=<value>
# This is REQUIRED — without it all logins return HTTP 500.

# ── WhatsApp Gateway (optional) ─────────────────────────────
# Self-hosted gateway URL. Leave blank to use manual-share mode.
WHATSAPP_GATEWAY_URL=

# Required when running whatsapp-gateway.js (HuggingFace / self-hosted)
SUPABASE_ANON_KEY=<same-as-above>
SUPABASE_SERVICE_KEY=<service-role-key-for-gateway-storage>

# ── Vercel Deployment ───────────────────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables.
# They mirror the values above and are injected at build/runtime.
# VERCEL_SUPABASE_URL         → same as SUPABASE_URL
# VERCEL_SUPABASE_ANON_KEY    → same as SUPABASE_ANON_KEY

# ── Android Release Signing ──────────────────────────────────
# Set these in android-app/gradle.properties (gitignored).
# See android-app/app/build.gradle for keytool instructions.
# RELEASE_STORE_FILE=../release.jks
# RELEASE_STORE_PASSWORD=
# RELEASE_KEY_ALIAS=
# RELEASE_KEY_PASSWORD=

# ── Runtime Config Endpoint (web) ───────────────────────────
# /api/config.js (Vercel Serverless Function) reads these two vars
# and serves them to the browser at runtime.  The browser never
# receives them at build time — no hardcoding in HTML/JS source.
# Set these in Vercel → Project Settings → Environment Variables.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
