              <option value="232">🇸🇱 +232</option>
              <option value="421">🇸🇰 +421</option>
              <option value="386">🇸🇮 +386</option>
              <option value="252">🇸🇴 +252</option>
              <option value="82">🇰🇷 +82</option>
              <option value="34">🇪🇸 +34</option>
              <option value="249">🇸🇩 +249</option>
              <option value="46">🇸🇪 +46</option>
              <option value="41">🇨🇭 +41</option>
              <option value="963">🇸🇾 +963</option>
              <option value="886">🇹🇼 +886</option>
              <option value="992">🇹🇯 +992</option>
              <option value="255">🇹🇿 +255</option>
              <option value="66">🇹🇭 +66</option>
              <option value="228">🇹🇬 +228</option>
              <option value="216">🇹🇳 +216</option>
              <option value="90">🇹🇷 +90</option>
              <option value="993">🇹🇲 +993</option>
              <option value="256">🇺🇬 +256</option>
              <option value="380">🇺🇦 +380</option>
              <option value="598">🇺🇾 +598</option>
              <option value="998">🇺🇿 +998</option>
              <option value="58">🇻🇪 +58</option>
              <option value="84">🇻🇳 +84</option>
              <option value="967">🇾🇪 +967</option>
              <option value="260">🇿🇲 +260</option>
              <option value="263">🇿🇼 +263</option>
            </select>
            <input type="tel" id="reg-whatsapp" class="form-input" placeholder="e.g. 9876543210" required autocomplete="tel-national" inputmode="numeric">
            <i class="fa-brands fa-whatsapp"></i>
          </div>
        </div>
          </div>
        </section>

        <section class="form-section">
          <div class="form-section-head"><div><strong>Administrator account</strong><span>Create the first manager-level credential for this outlet.</span></div><span class="section-count">03</span></div>
          <div class="form-grid">
        <div class="form-group">
          <label for="reg-user">Admin Username</label>
          <input type="text" id="reg-user" class="form-input" placeholder="e.g. admin" required autocomplete="username" autocapitalize="none" spellcheck="false">
          <i class="fa-solid fa-user-gear input-icon"></i>
        </div>

        <div class="form-group">
          <label for="reg-pass">Admin Password</label>
          <input type="password" id="reg-pass" class="form-input password-input" placeholder="Choose a strong password" required autocomplete="new-password" minlength="10">
          <i class="fa-solid fa-key input-icon"></i>
          <button class="toggle-pwd" id="toggle-reg-pwd" type="button" aria-label="Show registration password" aria-pressed="false"><i class="fa-solid fa-eye" aria-hidden="true"></i></button>
          <p class="field-help">Use at least 10 characters and avoid reusing a personal password.</p>
        </div>
          </div>
        </section>

        <label class="legal-check">
          <input type="checkbox" id="registration-consent" required>
          <span>I confirm that I am authorized to register this outlet and agree to the <a href="terms.html" target="_blank">Terms</a> and <a href="privacy.html" target="_blank">Privacy Policy</a>.</span>
        </label>

        <button type="submit" class="submit-btn">
          Submit registration request <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
        </button>
        <div class="registration-note"><i class="fa-solid fa-circle-info" aria-hidden="true"></i><span>Submitting does not charge you or activate a subscription. CodeArc reviews the request before issuing workspace access.</span></div>
      </form>

    </div>
  </div>
  </main>

  <footer class="access-footer">
    <span>© 2026 CodeArc Tech Labs Private Limited</span>
    <div class="access-footer-links"><a href="terms.html">Terms</a><a href="privacy.html">Privacy</a><a href="refund-policy.html">Refund policy</a></div>
  </footer>

  <script>
    // Credentials are loaded at runtime by /config.js → /api/config (Vercel env vars).
    // NEVER hardcode these values here — rotate via Supabase Dashboard + Vercel env update.
    const DEFAULT_SUPABASE_URL = window.__SUPABASE_URL__ || '';
    const DEFAULT_SUPABASE_KEY = window.__SUPABASE_ANON_KEY__ || '';
    const TENANT_ACCESS_FUNCTION_URL = DEFAULT_SUPABASE_URL
      ? `${DEFAULT_SUPABASE_URL}/functions/v1/tenant-access`
      : '';

    let supabaseClient = null;
    if (typeof supabase !== 'undefined') {
      supabaseClient = supabase.createClient(DEFAULT_SUPABASE_URL, DEFAULT_SUPABASE_KEY);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const loginCard = document.getElementById('login-card');
      
      // --- INTERACTIVE STEAM, AROMA & BOKEH DYNAMIC CANVAS ---
      (function() {
        return;
        const canvas = document.createElement('canvas');
        canvas.id = 'aroma-canvas';
        canvas.style.position = 'fixed';
        canvas.style.top = '0';
        canvas.style.left = '0';
        canvas.style.width = '100vw';
        canvas.style.height = '100vh';
        canvas.style.zIndex = '0';
        canvas.style.pointerEvents = 'none';
        document.body.prepend(canvas);

        const ctx = canvas.getContext('2d');
        let width = window.innerWidth;
        let height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;

        let mouse = { x: -1000, y: -1000, radius: 180 };
        let time = 0;
        let cardRect = null;

        // Resize handler
        window.addEventListener('resize', () => {
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = width;
          canvas.height = height;
        });

        // Track cursor/touch coordinate
        window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;
        });

        window.addEventListener('mouseleave', () => {
          mouse.x = -1000;
          mouse.y = -1000;
        });

        window.addEventListener('touchmove', (e) => {
          if (e.touches.length > 0) {
            mouse.x = e.touches[0].clientX;
            mouse.y = e.touches[0].clientY;
          }
        }, { passive: true });

        window.addEventListener('touchend', () => {
          mouse.x = -1000;
          mouse.y = -1000;
        });

        // 1. Ambient Bokeh Orbs (Slow floating warm blobs)
        class BokehOrb {
          constructor(color) {
            this.color = color; // '252, 128, 25' (orange) or '226, 55, 68' (red)
            this.reset();
          }

          reset() {
            this.x = Math.random() * width;
            this.y = Math.random() * height;
            this.radius = Math.random() * 180 + 150; // Size 150px - 330px
            this.vx = (Math.random() - 0.5) * 0.25;
            this.vy = (Math.random() - 0.5) * 0.25;
            this.alpha = Math.random() * 0.035 + 0.015; // Very subtle transparency
          }

          update() {
            this.x += this.vx;
            this.y += this.vy;

            // Bounce off boundaries
            if (this.x - this.radius < 0) this.vx = Math.abs(this.vx);
            else if (this.x + this.radius > width) this.vx = -Math.abs(this.vx);

            if (this.y - this.radius < 0) this.vy = Math.abs(this.vy);
            else if (this.y + this.radius > height) this.vy = -Math.abs(this.vy);

            // Attract to mouse very gently
            const dx = mouse.x - this.x;
            const dy = mouse.y - this.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 400) {
              this.vx += (dx / dist) * 0.003;
              this.vy += (dy / dist) * 0.003;
            }

            // Cap speed
            const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
            if (speed > 0.4) {
              this.vx = (this.vx / speed) * 0.4;
              this.vy = (this.vy / speed) * 0.4;
            }
          }

          draw() {
            ctx.save();
            const grad = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.radius);
            grad.addColorStop(0, `rgba(${this.color}, ${this.alpha})`);
            grad.addColorStop(0.5, `rgba(${this.color}, ${this.alpha * 0.3})`);
            grad.addColorStop(1, `rgba(${this.color}, 0)`);
            ctx.fillStyle = grad;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          }
        }

        // 2. Aroma Steam Ribbons (Soft bezier curves flowing around loginCard)
        class SteamRibbon {
          constructor(x, width, speed, opacity, color1, color2) {
            this.x = x;
            this.width = width;
            this.speed = speed;
            this.opacity = opacity;
            this.color1 = color1; // 'rgba(252, 128, 25, '
            this.color2 = color2; // 'rgba(226, 55, 68, '
            this.offset = Math.random() * 50;
          }

          draw() {
            const segments = 22;
            const step = height / segments;
            
            ctx.save();
            const grad = ctx.createLinearGradient(0, height, 0, 0);
            grad.addColorStop(0, this.color1 + '0)'); // transparent at bottom
            grad.addColorStop(0.2, this.color1 + this.opacity + ')');
            grad.addColorStop(0.6, this.color2 + (this.opacity * 0.7) + ')');
            grad.addColorStop(1, this.color1 + '0)'); // transparent at top
            
            ctx.strokeStyle = grad;
            ctx.lineWidth = this.width;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            // Soft blur visual glow for steam
            ctx.shadowBlur = 12;
            ctx.shadowColor = this.color1 + (this.opacity * 0.2) + ')';
            
            ctx.beginPath();

            let points = [];
            for (let i = 0; i <= segments; i++) {
              const y = height - (i * step);
              const angle = (time * this.speed) + (i * 0.12) + this.offset;
              
              // Base swaying oscillation
              let waveX = Math.sin(angle) * 28;
              
              // Spread out slightly as it rises
              waveX *= (1 + (i / segments) * 1.3);
              
              let currentX = this.x + waveX;
              
              // Flow around the loginCard
              if (cardRect) {
                const rect = cardRect;
                const pad = this.width * 0.4 + 12;
                const cardLeft = rect.left - pad;
                const cardRight = rect.right + pad;
                const cardTop = rect.top - pad;
                const cardBottom = rect.bottom + pad;
                
                if (y > cardTop && y < cardBottom && currentX > cardLeft && currentX < cardRight) {
                  const distToLeft = currentX - cardLeft;
                  const distToRight = cardRight - currentX;
                  // Push smoothly to the closer side
                  if (distToLeft < distToRight) {
                    currentX = cardLeft - Math.sin(i * 0.2) * 10;
                  } else {
                    currentX = cardRight + Math.sin(i * 0.2) * 10;
                  }
                }
              }

              // Repulse gently from mouse cursor
              const mdx = currentX - mouse.x;
              const mdy = y - mouse.y;
              const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
              if (mdist < mouse.radius) {
                const force = (mouse.radius - mdist) / mouse.radius;
                currentX += (mdx / mdist) * force * 50;
              }

              points.push({ x: currentX, y: y });
            }

            // Draw smooth curve using coordinates
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 0; i < points.length - 1; i++) {
              const xc = (points[i].x + points[i + 1].x) / 2;
              const yc = (points[i].y + points[i + 1].y) / 2;
              ctx.quadraticCurveTo(points[i].x, points[i].y, xc, yc);
            }
            ctx.lineTo(points[points.length - 1].x, points[points.length - 1].y);
            ctx.stroke();
            ctx.restore();
          }
        }

        // 3. Glowing Aroma Sparks (tiny floating particles)
        class AromaSpark {
          constructor() {
            this.reset(true);
          }

          reset(initial = false) {
            this.x = Math.random() * width;
            this.y = initial ? Math.random() * height : height + 10;
            this.radius = Math.random() * 2 + 1.2;
            this.vx = (Math.random() - 0.5) * 0.4;
            this.vy = -(Math.random() * 0.7 + 0.5); // drift upward
            this.alpha = Math.random() * 0.55 + 0.25;
            this.decay = Math.random() * 0.004 + 0.0015;
            this.color = Math.random() > 0.5 ? '252, 128, 25' : '226, 55, 68'; // Orange/Red
            this.waveSpeed = Math.random() * 0.015 + 0.008;
            this.waveAngle = Math.random() * Math.PI * 2;
            this.waveAmplitude = Math.random() * 0.4 + 0.15;
          }

          update() {
            this.waveAngle += this.waveSpeed;
            this.x += this.vx + Math.sin(this.waveAngle) * this.waveAmplitude;
            this.y += this.vy;
            this.alpha -= this.decay;

            // Float around card boundaries
            if (cardRect) {
              const rect = cardRect;
              const pad = this.radius + 4;
              if (this.x + pad > rect.left && this.x - pad < rect.right &&
                  this.y + pad > rect.top && this.y - pad < rect.bottom) {
                
                const overlapLeft = (this.x + pad) - rect.left;
                const overlapRight = rect.right - (this.x - pad);
                const overlapTop = (this.y + pad) - rect.top;
                const overlapBottom = rect.bottom - (this.y - pad);
                
                const minOverlap = Math.min(overlapLeft, overlapRight, overlapTop, overlapBottom);
                
                if (minOverlap === overlapLeft) {
                  this.x = rect.left - pad;
                  this.vx = -Math.abs(this.vx) * 0.6;
                } else if (minOverlap === overlapRight) {
                  this.x = rect.right + pad;
                  this.vx = Math.abs(this.vx) * 0.6;
                } else if (minOverlap === overlapTop) {
                  this.y = rect.top - pad;
                  this.vy = -Math.abs(this.vy) * 0.6;
                } else {
                  this.y = rect.bottom + pad;
                  this.vy = Math.abs(this.vy) * 0.6;
                }
              }
            }

            // Mouse interaction push
            const dx = this.x - mouse.x;
            const dy = this.y - mouse.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 160) {
              const force = (160 - dist) / 160;
              this.x += (dx / dist) * force * 1.6;
              this.y += (dy / dist) * force * 1.6;
            }

            if (this.alpha <= 0 || this.y < -10) {
              this.reset(false);
            }
          }

          draw() {
            ctx.save();
            ctx.shadowBlur = 5;
            ctx.shadowColor = `rgba(${this.color}, ${this.alpha})`;
            ctx.fillStyle = `rgba(${this.color}, ${this.alpha})`;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          }
        }

        // Initialize animation components
        let items = [];
        
        // Add 3-4 soft background bokeh orbs
        items.push(new BokehOrb('252, 128, 25')); // orange
        items.push(new BokehOrb('226, 55, 68')); // red
        items.push(new BokehOrb('252, 128, 25')); // orange
        
        // Add 4-6 steam ribbons depending on screen size
        const ribbonCount = width < 480 ? 3 : 5;
        const spacing = width / (ribbonCount + 1);
        for (let i = 0; i < ribbonCount; i++) {
          const xPos = spacing * (i + 1);
          // Alternating color variables
          const isOrange = i % 2 === 0;
          const c1 = isOrange ? 'rgba(252, 128, 25, ' : 'rgba(226, 55, 68, ';
          const c2 = isOrange ? 'rgba(226, 55, 68, ' : 'rgba(252, 128, 25, ';
          
          items.push(new SteamRibbon(
            xPos, 
            Math.random() * 40 + 50,      // Ribbon width 50px - 90px
            Math.random() * 0.01 + 0.008,  // sway speed
            Math.random() * 0.02 + 0.015,  // low opacity: 0.015 - 0.035
            c1, 
            c2
          ));
        }

        // Add glowing sparks
        const sparkCount = width < 480 ? 15 : 45;
        for (let i = 0; i < sparkCount; i++) {
          items.push(new AromaSpark());
        }

        // Kinetic splash click wave
        window.addEventListener('pointerdown', (e) => {
          const clickX = e.clientX;
          const clickY = e.clientY;
          
          // Spawn extra sparks swirling upwards from click point
          const splashSparks = width < 480 ? 6 : 15;
          for (let i = 0; i < splashSparks; i++) {
            const spark = new AromaSpark();
            spark.x = clickX + (Math.random() - 0.5) * 30;
            spark.y = clickY + (Math.random() - 0.5) * 30;
            const angle = Math.random() * Math.PI * 2;
            const speed = Math.random() * 2.5 + 1.0;
            spark.vx = Math.cos(angle) * speed;
            spark.vy = Math.sin(angle) * speed - 1.0; // rising bias
            spark.alpha = 0.9;
            spark.decay = Math.random() * 0.012 + 0.008; // decay faster
            items.push(spark);
          }
        });

        function loop() {
          time += 1;
          ctx.clearRect(0, 0, width, height);
          cardRect = loginCard ? loginCard.getBoundingClientRect() : null;

          // Update & Draw all items
          items.forEach((item, index) => {
            if (item.update) {
              item.update();
              // Remove dead sparks from array to keep it clean
              if (item instanceof AromaSpark && item.alpha <= 0) {
                // If it's a temp click spark, delete it; otherwise keep recycling
                if (items.length > (3 + ribbonCount + sparkCount)) {
                  items.splice(index, 1);
                  return;
                }
              }
            }
            item.draw();
          });

          requestAnimationFrame(loop);
        }
        loop();
      })();

      const tabLoginBtn = document.getElementById('tab-login-btn');
      const tabRegisterBtn = document.getElementById('tab-register-btn');
      
      const loginForm = document.getElementById('login-form');
      const registerForm = document.getElementById('register-form');
      
      const errorBox = document.getElementById('error-box');
      const successBox = document.getElementById('success-box');
      
      const togglePwdBtn = document.getElementById('toggle-pwd');
      const passwordInput = document.getElementById('password');
      const toggleRegPwdBtn = document.getElementById('toggle-reg-pwd');
      const registerPasswordInput = document.getElementById('reg-pass');
      const recoveryModal = document.getElementById('recovery-modal');
      const recoveryRequestForm = document.getElementById('recovery-request-form');
      const recoveryResetForm = document.getElementById('recovery-reset-form');

      // Check URL query parameters for direct tab activation
      const urlParams = new URLSearchParams(window.location.search);
      const recoveryToken = urlParams.get('recovery') || '';
      if (urlParams.get('tab') === 'register') {
        activateRegisterTab();
      }

      function showError(msg) {
        successBox.style.display = 'none';
        errorBox.textContent = msg;
        errorBox.style.display = 'block';
        loginCard.classList.remove('shake-anim');
        void loginCard.offsetWidth; // trigger reflow
        loginCard.classList.add('shake-anim');
        if (window.AndroidInterface) window.AndroidInterface.vibrate(300);
        errorBox.focus({ preventScroll: true });
      }

      function showSuccess(msg) {
        errorBox.style.display = 'none';
        successBox.textContent = msg;
        successBox.style.display = 'block';
        if (window.AndroidInterface) window.AndroidInterface.vibrate(80);
        successBox.focus({ preventScroll: true });
      }

      function bindPasswordToggle(button, input, label) {
        if (!button || !input) return;
        button.addEventListener('click', () => {
          const showing = input.type === 'text';
          const icon = button.querySelector('i');
          input.type = showing ? 'password' : 'text';
          button.setAttribute('aria-pressed', String(!showing));
          button.setAttribute('aria-label', `${showing ? 'Show' : 'Hide'} ${label}`);
          if (icon) {
            icon.classList.toggle('fa-eye', showing);
            icon.classList.toggle('fa-eye-slash', !showing);
          }
        });
      }

      bindPasswordToggle(togglePwdBtn, passwordInput, 'password');
      bindPasswordToggle(toggleRegPwdBtn, registerPasswordInput, 'registration password');

      function setFormBusy(form, busy, busyText) {
        const button = form ? form.querySelector('button[type="submit"]') : null;
        if (!button) return;
        if (!button.dataset.defaultHtml) button.dataset.defaultHtml = button.innerHTML;
        button.disabled = busy;
        button.setAttribute('aria-busy', String(busy));
        button.innerHTML = busy
          ? `<i class="fa-solid fa-circle-notch fa-spin" aria-hidden="true"></i> ${busyText}`
          : button.dataset.defaultHtml;
      }

      function updateTabState(activeTab) {
        const loginActive = activeTab === 'login';
        tabLoginBtn.classList.toggle('active', loginActive);
        tabRegisterBtn.classList.toggle('active', !loginActive);
        tabLoginBtn.setAttribute('aria-selected', String(loginActive));
        tabRegisterBtn.setAttribute('aria-selected', String(!loginActive));
        loginForm.hidden = !loginActive;
        registerForm.hidden = loginActive;
        loginForm.style.display = loginActive ? 'block' : 'none';
        registerForm.style.display = loginActive ? 'none' : 'block';
        document.body.classList.toggle('register-mode', !loginActive);
      }

      // Switch tabs
      tabLoginBtn.addEventListener('click', () => {
        updateTabState('login');
        document.getElementById('portal-title').textContent = "Sign in to your workspace";
        document.getElementById('portal-subtitle').textContent = "Enter the outlet ID and staff credentials assigned to you.";
        document.title = "Sign In | CodeArc RestroSuite";
        history.replaceState(null, '', 'login.html');
        errorBox.style.display = 'none';
        successBox.style.display = 'none';
      });

      function activateRegisterTab() {
        updateTabState('register');
        document.getElementById('portal-title').textContent = "Request a RestroSuite workspace";
        document.getElementById('portal-subtitle').textContent = "Share your outlet and administrator details for account review.";
        document.title = "Register Your Outlet | CodeArc RestroSuite";
        history.replaceState(null, '', 'login.html?tab=register');
        errorBox.style.display = 'none';
        successBox.style.display = 'none';
      }

      tabRegisterBtn.addEventListener('click', activateRegisterTab);

      // Real-time Slug Suggestion & Database Check
      const regNameInput = document.getElementById('reg-name');
      const regSlugInput = document.getElementById('reg-slug');
      const slugStatus = document.getElementById('slug-status');
      let isSlugEditedManually = false;
      let checkTimeout = null;

      // Track manual edits to the slug field
      if (regSlugInput) {
        regSlugInput.addEventListener('input', () => {
          isSlugEditedManually = true;
          triggerAvailabilityCheck(regSlugInput.value);
        });
      }

      // Convert business name to suggested slug in real-time
      if (regNameInput && regSlugInput) {
        regNameInput.addEventListener('input', (e) => {
          if (!isSlugEditedManually) {
            let suggestedSlug = e.target.value
              .toLowerCase()
              .replace(/[\s_]+/g, '-')          // spaces/underscores to hyphens
              .replace(/[^a-z0-9-]/g, '')        // remove special chars
              .replace(/-+/g, '-')              // consolidate consecutive hyphens
              .replace(/^-+|-+$/g, '');         // trim leading/trailing hyphens
            
            regSlugInput.value = suggestedSlug;
            triggerAvailabilityCheck(suggestedSlug);
          }
        });
      }

      // Helper to debounce database calls (waits 400ms after typing stops)
      function triggerAvailabilityCheck(slug) {
        if (checkTimeout) clearTimeout(checkTimeout);
        
        if (!slug) {
          if (slugStatus) {
            slugStatus.style.display = 'none';
          }
          return;
        }

        if (slugStatus) {
          slugStatus.style.display = 'block';
          slugStatus.style.color = 'var(--text-muted)';
          slugStatus.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Checking availability...';
        }

        checkTimeout = setTimeout(() => {
          runAvailabilityQuery(slug);
        }, 400);
      }

      // Query Supabase for slug existence
      async function runAvailabilityQuery(slug) {
        if (!slugStatus) return;
        
        if (!supabaseClient) {
          slugStatus.style.color = '#ef4444';
          slugStatus.textContent = "Backend connection is offline.";
          return;
        }

        try {
          const response = await fetch(TENANT_ACCESS_FUNCTION_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': DEFAULT_SUPABASE_KEY,
              'Authorization': `Bearer ${DEFAULT_SUPABASE_KEY}`
            },
            body: JSON.stringify({
              action: 'check_slug',
              slug
            })
          });

          const result = await response.json();
          if (!response.ok) throw new Error(result.error || 'Availability check failed.');

          // Double check if the current input still matches the queried slug (to avoid race conditions)
          if (regSlugInput && regSlugInput.value !== slug) return;

          if (!result.available) {
            slugStatus.style.color = '#ef4444'; // Error Red
            slugStatus.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Already registered (Not Available)';
          } else {
            slugStatus.style.color = 'var(--success)'; // Success Green
            slugStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> Unique ID Available';
          }
        } catch (err) {
          console.error("Availability check failed:", err);
          slugStatus.style.color = '#ef4444';
          slugStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Error checking availability';
        }
      }

      // Auto-sanitize Slug Inputs (converting spaces/special chars to hyphens, lowercase, etc.)
      const sanitizeSlugInput = (inputEl) => {
        if (!inputEl) return;
        inputEl.addEventListener('input', (e) => {
          let val = e.target.value;
          val = val.replace(/[\s_]+/g, '-');
          val = val.toLowerCase();
          val = val.replace(/[^a-z0-9-]/g, '');
          val = val.replace(/-+/g, '-');
          e.target.value = val;
        });
      };

      sanitizeSlugInput(document.getElementById('reg-slug'));
      sanitizeSlugInput(document.getElementById('tenant-id'));

      async function callTenantAccess(action, payload) {
        const response = await fetch(TENANT_ACCESS_FUNCTION_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': DEFAULT_SUPABASE_KEY,
            'Authorization': `Bearer ${DEFAULT_SUPABASE_KEY}`
          },
          body: JSON.stringify({
            action,
            ...payload
          })
        });

        const result = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(result.error || 'Request failed.');
        }

        return result;
      }

      function openRecoveryModal(resetMode = false) {
        recoveryModal.classList.add('active');
        recoveryModal.setAttribute('aria-hidden', 'false');
        recoveryRequestForm.hidden = resetMode;
        recoveryResetForm.hidden = !resetMode;
        document.getElementById('recovery-guidance').hidden = resetMode;
        document.getElementById('recovery-title').textContent = resetMode ? 'Set a new password' : 'Recover credentials';
        document.getElementById('recovery-subtitle').textContent = resetMode
          ? 'This single-use recovery link expires after 30 minutes.'
          : 'Outlet owners can receive the outlet ID, username, and a secure reset link at the registered email.';
        setTimeout(() => {
          document.getElementById(resetMode ? 'recovery-new-password' : 'recovery-slug').focus();
        }, 50);
      }

      function closeRecoveryModal() {
        recoveryModal.classList.remove('active');
        recoveryModal.setAttribute('aria-hidden', 'true');
      }

      document.getElementById('open-recovery-btn').addEventListener('click', () => {
        const slug = document.getElementById('tenant-id').value.trim();
        if (slug) document.getElementById('recovery-slug').value = slug;
        openRecoveryModal(false);
      });
      document.getElementById('close-recovery-btn').addEventListener('click', closeRecoveryModal);
      recoveryModal.addEventListener('click', event => {
        if (event.target === recoveryModal) closeRecoveryModal();
      });

      recoveryRequestForm.addEventListener('submit', async event => {
        event.preventDefault();
        setFormBusy(recoveryRequestForm, true, 'Sending recovery link...');
        try {
          const result = await callTenantAccess('request_recovery', {
            slug: document.getElementById('recovery-slug').value.trim().toLowerCase(),
            email: document.getElementById('recovery-email').value.trim().toLowerCase()
          });
          showSuccess(result.message || 'If the details match, a recovery link will be sent shortly.');
          closeRecoveryModal();
          recoveryRequestForm.reset();
        } catch (error) {
          showError(error.message || 'Recovery request failed.');
        } finally {
          setFormBusy(recoveryRequestForm, false);
        }
      });

      recoveryResetForm.addEventListener('submit', async event => {
        event.preventDefault();
        const password = document.getElementById('recovery-new-password').value;
        const confirmation = document.getElementById('recovery-confirm-password').value;
        if (password !== confirmation) {
          showError('The new passwords do not match.');
          return;
        }
        setFormBusy(recoveryResetForm, true, 'Updating password...');
        try {
          const result = await callTenantAccess('reset_password', { token: recoveryToken, password });
          history.replaceState(null, '', 'login.html');
          showSuccess(result.message || 'Password updated. You can now sign in.');
          closeRecoveryModal();
          recoveryResetForm.reset();
        } catch (error) {
          showError(error.message || 'Password reset failed.');
        } finally {
          setFormBusy(recoveryResetForm, false);
        }
      });

      if (recoveryToken) openRecoveryModal(true);

      // Handle login submit
      if (loginForm) {
        loginForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorBox.style.display = 'none';
          setFormBusy(loginForm, true, 'Verifying access...');
          
          const slugVal = document.getElementById('tenant-id').value.trim().toLowerCase();
          const userVal = document.getElementById('username').value.trim();
          const pwdVal = document.getElementById('password').value.trim();

          // Ensure Supabase is working
          if (!supabaseClient) {
            showError("Backend connection is offline. Cannot authenticate.");
            setFormBusy(loginForm, false);
            return;
          }

          try {
            const result = await callTenantAccess('login', {
              slug: slugVal,
              username: userVal,
              password: pwdVal
            });
            const session = result.session;
            sessionStorage.setItem('just_logged_in', 'true');
            sessionStorage.setItem('logged_in_user', session.username);
            sessionStorage.setItem('logged_in_display_name', session.display_name || session.username);
            sessionStorage.setItem('logged_in_role', session.role);
            sessionStorage.setItem('tenant_user_id', session.user_id || '');
            sessionStorage.setItem('tenant_id', session.tenant_id);
            sessionStorage.setItem('tenant_slug', session.tenant_slug);
            sessionStorage.setItem('tenant_name', session.tenant_name);
            sessionStorage.setItem('allowed_tabs', JSON.stringify(session.allowed_tabs || []));
            sessionStorage.setItem('tenant_plan_code', session.plan_code || '');
            sessionStorage.setItem('tenant_plan_name', session.plan_name || '');
            sessionStorage.setItem('tenant_subscription_status', session.subscription_status || '');
            sessionStorage.setItem('tenant_plan_limits', JSON.stringify(session.plan_limits || {}));
            sessionStorage.setItem('tenant_data_reset_at', session.data_reset_at || '');
            if (session.admin_token) {
              sessionStorage.setItem('superadmin_admin_token', session.admin_token);
            } else {
              sessionStorage.removeItem('superadmin_admin_token');
            }
            if (session.session_token) {
              sessionStorage.setItem('tenant_session_token', session.session_token);
            } else {
              sessionStorage.removeItem('tenant_session_token');
            }
            
            if (window.AndroidInterface) window.AndroidInterface.vibrate(80);
            window.location.href = 'dashboard.html';
          } catch (err) {
            showError(err.message || "Authentication failed.");
          } finally {
            setFormBusy(loginForm, false);
          }
        });
      }

      // Handle registration submit
      if (registerForm) {
        registerForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          errorBox.style.display = 'none';
          setFormBusy(registerForm, true, 'Submitting request...');
          
          const name = document.getElementById('reg-name').value.trim();
          const slug = document.getElementById('reg-slug').value.trim().toLowerCase();
          const type = document.getElementById('reg-type').value;
          const email = document.getElementById('reg-email').value.trim();
          const countryCode = document.getElementById('reg-country-code').value;
          let whatsappRaw = document.getElementById('reg-whatsapp').value.trim().replace(/\D/g, '');
          
          // Strip leading 0 if entered
          if (whatsappRaw.startsWith('0')) {
            whatsappRaw = whatsappRaw.substring(1);
          }
          
          if (whatsappRaw.length < 7 || whatsappRaw.length > 12) {
            showError("Please enter a valid WhatsApp mobile number.");
            setFormBusy(registerForm, false);
            return;
          }
          
          const whatsapp = countryCode + whatsappRaw;
          const user = document.getElementById('reg-user').value.trim();
          const pass = document.getElementById('reg-pass').value.trim();

          // Validate slug (must be URL friendly)
          if (!/^[a-z0-9-]+$/.test(slug)) {
            showError("Slug can only contain lowercase letters, numbers, and hyphens (e.g. royal-dhaba).");
            setFormBusy(registerForm, false);
            return;
          }

          if (!supabaseClient) {
            showError("Backend connection is offline. Cannot register.");
            setFormBusy(registerForm, false);
            return;
          }

          try {
            const result = await callTenantAccess('register', {
              name,
              slug,
              outlet_type: type,
              email,
              phone: whatsapp,
              username: user,
              password: pass
            });
            showSuccess(result.message || "Registration submitted successfully! Please wait for CodeArc to approve your account.");
            
            // Note: Registration confirmation alerts (WhatsApp & Email) are now processed securely 
            // and asynchronously by the backend gateway server listening to Supabase Realtime changes on saas_tenants.
            // This eliminates token exposure in the public client-side frontend code.

            registerForm.reset();
            // Scroll to top of card to show success message
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } catch (err) {
            showError(err.message || "Registration failed.");
          } finally {
            setFormBusy(registerForm, false);
          }
        });
      }
    });
  </script>
  <script src="pwa.js"></script>
</body>