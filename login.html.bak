              <option value="675">🇵🇬 +675</option>
              <option value="595">🇵🇾 +595</option>
              <option value="51">🇵🇪 +51</option>
              <option value="63">🇵🇭 +63</option>
              <option value="48">🇵🇱 +48</option>
              <option value="351">🇵🇹 +351</option>
              <option value="40">🇷🇴 +40</option>
