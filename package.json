{
  "name": "codearc-restrosuite",
  "version": "2.0.0",
  "private": true,
  "description": "RestroSuite zero-cost restaurant SaaS on Vercel and Supabase, with an optional WhatsApp gateway add-on.",
  "scripts": {
    "start": "node whatsapp-gateway.js",
    "start:gateway": "node whatsapp-gateway.js",
    "check:free-tier": "node scripts/check-free-tier.cjs",
    "test": "node --test tests/*.test.cjs",
    "check": "node scripts/check-project.cjs && node scripts/check-free-tier.cjs",
    "check:launch": "node scripts/check-launch.cjs",
    "hash:superadmin": "node scripts/hash-superadmin-password.cjs",
    "backup": "node scripts/backup-db.js",
    "sync:android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./sync-assets.ps1",
    "build:android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android.ps1",
    "deploy:production": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1"
  },
  "engines": {
    "node": ">=20 <26"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lines-and-columns": "^2.0.4",
    "nodemailer": "^9.0.1",
    "@whiskeysockets/baileys": "^6.7.8",
    "pino": "^9.1.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "unzipper": "^0.12.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "eslint": "^10.6.0"
  }
}
