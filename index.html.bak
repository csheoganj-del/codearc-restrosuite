<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#172033">
  <meta name="description" content="CodeArc RestroSuite unifies restaurant POS billing, kitchen orders, inventory, customer loyalty, reports, and WhatsApp receipts in one reliable platform.">
  <meta name="robots" content="index, follow">
  <meta name="color-scheme" content="light">
  <meta property="og:type" content="website">
  <meta property="og:title" content="CodeArc RestroSuite | Run every restaurant operation from one place">
  <meta property="og:description" content="Faster billing, calmer kitchens, accurate stock, and clearer decisions for restaurants, cafes, dhabas, and food chains.">
  <meta property="og:image" content="images/restrosuite-social.png">
  <meta property="og:site_name" content="CodeArc RestroSuite">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="CodeArc RestroSuite">
  <meta name="twitter:description" content="One connected platform for restaurant billing, kitchen, inventory, loyalty, and reporting.">
  <link rel="canonical" href="https://codearc-restrosuite.vercel.app/">
  <link rel="icon" href="images/restrosuite-mark.png" type="image/png">
  <link rel="manifest" href="manifest.webmanifest">
  <title>CodeArc RestroSuite | Restaurant POS and Operations Platform</title>
  <style>
    :root {
      --ink: #172033;
      --ink-soft: #344054;
      --muted: #667085;
      --line: #e5e7eb;
      --line-strong: #d0d5dd;
      --paper: #fffdfa;
      --surface: #ffffff;
      --surface-soft: #f7f8fa;
      --surface-warm: #fff5ec;
      --brand: #f36f21;
      --brand-dark: #c94f0b;
      --brand-soft: #ffeadb;
      --accent: #4456d9;
      --accent-soft: #eef0ff;
      --success: #16845b;
      --success-soft: #e9f8f1;
      --warning: #b54708;
      --danger: #c4320a;
      --shadow-sm: 0 2px 8px rgba(23, 32, 51, 0.06);
      --shadow-md: 0 16px 42px rgba(23, 32, 51, 0.10);
      --shadow-lg: 0 28px 80px rgba(23, 32, 51, 0.16);
      --radius-sm: 10px;
      --radius-md: 16px;
      --radius-lg: 24px;
      --radius-xl: 34px;
      --max-width: 1200px;
      --ease: cubic-bezier(.2, .8, .2, 1);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 92px;
    }

    body {
      margin: 0;
      overflow-x: hidden;
      color: var(--ink);
      background: var(--paper);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    body.menu-open {
      overflow: hidden;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    button,
    a {
      -webkit-tap-highlight-color: transparent;
    }

    a {
      color: inherit;
    }

    img,
    svg {
      display: block;
      max-width: 100%;
    }

    section {
      position: relative;
    }

    :focus-visible {
      outline: 3px solid rgba(68, 86, 217, 0.42);
      outline-offset: 3px;
    }

    .skip-link {
      position: fixed;
      top: 8px;
      left: 8px;
      z-index: 2000;
      padding: 10px 14px;
      border-radius: 8px;
      color: #fff;
      background: var(--ink);
      transform: translateY(-150%);
      transition: transform 160ms ease;
    }

    .skip-link:focus {
      transform: translateY(0);
    }

    .container {
      width: min(calc(100% - 40px), var(--max-width));
      margin-inline: auto;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      color: var(--brand-dark);
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      width: 22px;
      height: 2px;
      background: currentColor;
      content: "";
    }

    .section-heading {
      max-width: 760px;
      margin-bottom: 48px;
    }

    .section-heading.center {
      margin-inline: auto;
      text-align: center;
    }

    .section-heading.center .eyebrow {
      justify-content: center;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1,
    h2,
    h3 {
      letter-spacing: -0.035em;
      line-height: 1.08;
    }

    h1 {
      margin-bottom: 24px;
      font-size: clamp(2.6rem, 6vw, 5.3rem);
    }

    h2 {
      margin-bottom: 18px;
      font-size: clamp(2rem, 4vw, 3.45rem);
    }

    h3 {
      margin-bottom: 12px;
      font-size: 1.22rem;
    }

    .section-heading p,
    .lead {
      color: var(--muted);
      font-size: clamp(1rem, 1.6vw, 1.16rem);
    }

    .btn {
      display: inline-flex;
      min-height: 48px;
      align-items: center;
      justify-content: center;
      gap: 9px;
      padding: 12px 20px;
      border: 1px solid transparent;
      border-radius: 12px;
      font-weight: 750;
      text-decoration: none;
      cursor: pointer;
      transition: color 180ms ease, background 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms var(--ease);
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      color: #fff;
      background: var(--brand);
      box-shadow: 0 10px 26px rgba(243, 111, 33, 0.22);
    }

    .btn-primary:hover {
      background: var(--brand-dark);
      box-shadow: 0 14px 30px rgba(201, 79, 11, 0.24);
    }

    .btn-secondary {
      border-color: var(--line-strong);
      color: var(--ink);
      background: rgba(255, 255, 255, 0.8);
    }

    .btn-secondary:hover {
      border-color: var(--ink);
      background: #fff;
    }

    .btn-dark {
      color: #fff;
      background: var(--ink);
    }

    .btn-dark:hover {
      background: #27334a;
    }

    .btn-link {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: var(--accent);
      font-weight: 750;
      text-decoration: none;
    }

    .icon {
      width: 20px;
      height: 20px;
      flex: 0 0 auto;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2;
    }

    .site-header {
      position: fixed;
      inset: 0 0 auto;
      z-index: 1000;
      border-bottom: 1px solid transparent;
      background: rgba(255, 253, 250, 0.84);
      backdrop-filter: blur(18px);
      transition: border-color 180ms ease, box-shadow 180ms ease;
    }

    .site-header.scrolled {
      border-color: rgba(208, 213, 221, 0.8);
      box-shadow: var(--shadow-sm);
    }

    .nav-wrap {
      display: flex;
      min-height: 74px;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 1.04rem;
      font-weight: 850;
      letter-spacing: -0.025em;
      text-decoration: none;
      white-space: nowrap;
    }

    .brand-mark {
      position: relative;
      display: grid;
      width: 36px;
      height: 36px;
      place-items: center;
      overflow: hidden;
      border-radius: 11px;
      color: #fff;
      background: var(--ink);
    }

    .brand-mark::before,
    .brand-mark::after {
      position: absolute;
      border-radius: 999px;
      content: "";
    }

    .brand-mark::before {
      width: 17px;
      height: 17px;
      background: var(--brand);
      transform: translate(-4px, 4px);
    }

    .brand-mark::after {
      width: 8px;
      height: 8px;
      background: #fff;
      transform: translate(7px, -7px);
    }

    .brand-product {
      color: var(--brand);
    }

    .desktop-nav {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    .desktop-nav a {
      position: relative;
      color: var(--ink-soft);
      font-size: 0.91rem;
      font-weight: 650;
      text-decoration: none;
    }

    .desktop-nav a::after {
      position: absolute;
      right: 0;
      bottom: -9px;
      left: 0;
      height: 2px;
      background: var(--brand);
      content: "";
      transform: scaleX(0);
      transition: transform 180ms ease;
    }

    .desktop-nav a:hover::after,
    .desktop-nav a[aria-current="true"]::after {
      transform: scaleX(1);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .nav-signin {
      padding: 10px;
      color: var(--ink-soft);
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
    }

    .menu-toggle {
      display: none;
      width: 44px;
      height: 44px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 11px;
      color: var(--ink);
      background: #fff;
      cursor: pointer;
    }

    .menu-toggle span,
    .menu-toggle::before,
    .menu-toggle::after {
      width: 20px;
      height: 2px;
      border-radius: 2px;
      background: currentColor;
      content: "";
      transition: transform 180ms ease, opacity 180ms ease;
    }

    .menu-toggle {
      gap: 4px;
    }

    .menu-toggle[aria-expanded="true"] span {
      opacity: 0;
    }

    .menu-toggle[aria-expanded="true"]::before {
      transform: translateY(6px) rotate(45deg);
    }

    .menu-toggle[aria-expanded="true"]::after {
      transform: translateY(-6px) rotate(-45deg);
    }

    .mobile-menu {
      display: none;
      padding: 8px 20px 22px;
      border-top: 1px solid var(--line);
      background: var(--paper);
    }

    .mobile-menu.open {
      display: grid;
      gap: 4px;
    }

    .mobile-menu a {
      padding: 13px 10px;
      border-radius: 9px;
      font-weight: 700;
      text-decoration: none;
    }

    .mobile-menu a:hover {
      background: var(--surface-warm);
    }

    .hero {
      min-height: 790px;
      padding: 150px 0 94px;
      overflow: hidden;
      background:
        radial-gradient(circle at 8% 20%, rgba(243, 111, 33, 0.13), transparent 26%),
        radial-gradient(circle at 86% 18%, rgba(68, 86, 217, 0.12), transparent 25%),
        linear-gradient(180deg, #fffdfa 0%, #fff 72%);
    }

    .hero::before {
      position: absolute;
      inset: 0;
      opacity: 0.28;
      background-image: linear-gradient(rgba(23, 32, 51, .055) 1px, transparent 1px), linear-gradient(90deg, rgba(23, 32, 51, .055) 1px, transparent 1px);
      background-size: 52px 52px;
      mask-image: linear-gradient(to bottom, #000, transparent 78%);
      content: "";
      pointer-events: none;
    }

    .hero-grid {
      display: grid;
      position: relative;
      z-index: 1;
      grid-template-columns: minmax(0, 0.92fr) minmax(500px, 1.08fr);
      align-items: center;
      gap: 66px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      margin-bottom: 24px;
      padding: 7px 11px;
      border: 1px solid #fed7bb;
      border-radius: 999px;
      color: #9f3f09;
      background: rgba(255, 245, 236, 0.9);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .live-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
      box-shadow: 0 0 0 5px rgba(22, 132, 91, 0.12);
    }

    .hero h1 span {
      color: var(--brand);
    }

    .hero-copy > p {
      max-width: 650px;
      margin-bottom: 30px;
      color: var(--muted);
      font-size: 1.12rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 24px;
    }

    .hero-assurances {
      display: flex;
      flex-wrap: wrap;
      gap: 17px;
      color: var(--ink-soft);
      font-size: 0.83rem;
      font-weight: 700;
    }

    .hero-assurances span {
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }

    .hero-assurances .icon {
      width: 16px;
      color: var(--success);
    }

    .product-stage {
      position: relative;
      min-height: 550px;
      perspective: 1200px;
    }

    .dashboard {
      position: absolute;
      inset: 30px 0 auto;
      overflow: hidden;
      border: 1px solid rgba(208, 213, 221, 0.9);
      border-radius: 22px;
      background: #fff;
      box-shadow: var(--shadow-lg);
      transform: rotateY(-3deg) rotateX(1deg);
      transform-origin: center;
      transition: transform 600ms var(--ease);
    }

    .product-stage:hover .dashboard {
      transform: rotateY(0) rotateX(0);
    }

    .dash-topbar {
      display: flex;
      height: 48px;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      border-bottom: 1px solid var(--line);
      background: #fbfcfd;
    }

    .window-dots {
      display: flex;
      gap: 5px;
    }

    .window-dots span {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #d0d5dd;
    }

    .window-dots span:first-child {
      background: #f97066;
    }

    .window-dots span:nth-child(2) {
      background: #fdb022;
    }

    .window-dots span:last-child {
      background: #32d583;
    }

    .dash-title {
      font-size: 0.72rem;
      font-weight: 800;
    }

    .dash-live {
      color: var(--success);
      font-size: 0.67rem;
      font-weight: 800;
    }

    .dash-body {
      display: grid;
      min-height: 420px;
      grid-template-columns: 62px 1fr;
    }

    .dash-sidebar {
      display: flex;
      align-items: center;
      flex-direction: column;
      gap: 13px;
      padding: 18px 10px;
      border-right: 1px solid var(--line);
      color: #98a2b3;
      background: var(--ink);
    }

    .dash-sidebar span {
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 9px;
      font-size: 0.68rem;
      font-weight: 800;
    }

    .dash-sidebar .active {
      color: #fff;
      background: var(--brand);
    }

    .dash-content {
      padding: 18px;
      background: #f7f8fa;
    }

    .dash-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 12px;
    }

    .dash-stat {
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 11px;
      background: #fff;
    }

    .dash-stat small {
      display: block;
      margin-bottom: 5px;
      color: var(--muted);
      font-size: 0.62rem;
      font-weight: 700;
    }

    .dash-stat strong {
      font-size: 0.98rem;
    }

    .dash-panels {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 12px;
    }

    .dash-panel {
      min-height: 242px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 0.68rem;
      font-weight: 850;
    }

    .panel-head span {
      padding: 3px 7px;
      border-radius: 999px;
      color: var(--brand-dark);
      background: var(--brand-soft);
      font-size: 0.55rem;
    }

    .order-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px dashed var(--line);
      color: var(--ink-soft);
      font-size: 0.62rem;
    }

    .order-total {
      display: flex;
      justify-content: space-between;
      margin-top: 12px;
      font-size: 0.7rem;
      font-weight: 850;
    }

    .pay-bar {
      margin-top: 13px;
      padding: 8px;
      border-radius: 7px;
      color: #fff;
      background: var(--brand);
      font-size: 0.6rem;
      font-weight: 800;
      text-align: center;
    }

    .ticket {
      padding: 10px;
      border-left: 3px solid var(--accent);
      border-radius: 8px;
      background: var(--accent-soft);
    }

    .ticket-title {
      display: flex;
      justify-content: space-between;
      margin-bottom: 9px;
      font-size: 0.61rem;
      font-weight: 850;
    }

    .ticket ul {
      margin: 0;
      padding-left: 15px;
      color: var(--ink-soft);
      font-size: 0.58rem;
    }

    .ticket-progress {
      height: 5px;
      margin-top: 12px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(68, 86, 217, 0.15);
    }

    .ticket-progress span {
      display: block;
      width: 68%;
      height: 100%;
      background: var(--accent);
      animation: prep 4s var(--ease) infinite alternate;
    }

    .flow-chip {
      position: absolute;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border: 1px solid rgba(208, 213, 221, 0.88);
      border-radius: 13px;
      background: rgba(255, 255, 255, 0.95);
      box-shadow: var(--shadow-md);
      font-size: 0.72rem;
      font-weight: 800;
      animation: float 5s var(--ease) infinite;
    }

    .flow-chip .chip-icon {
      display: grid;
      width: 31px;
      height: 31px;
      place-items: center;
      border-radius: 9px;
      color: var(--accent);
      background: var(--accent-soft);
    }

    .chip-kitchen {
      top: 0;
      right: 30px;
    }

    .chip-stock {
      right: -18px;
      bottom: 58px;
      animation-delay: -1.5s;
    }

    .chip-receipt {
      bottom: 0;
      left: 18px;
      animation-delay: -3s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes prep {
      from { width: 36%; }
      to { width: 88%; }
    }

    .proof-strip {
      padding: 24px 0;
      border-block: 1px solid var(--line);
      background: #fff;
    }

    .proof-grid {
      display: grid;
      grid-template-columns: 1.3fr repeat(4, 1fr);
      align-items: center;
    }

    .proof-intro {
      padding-right: 30px;
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 700;
    }

    .proof-item {
      padding: 4px 22px;
      border-left: 1px solid var(--line);
    }

    .proof-item strong {
      display: block;
      color: var(--ink);
      font-size: 1.35rem;
      letter-spacing: -0.035em;
    }

    .proof-item span {
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 650;
    }

    .workflow {
      padding: 112px 0;
    }

    .workflow-stage {
      display: grid;
      grid-template-columns: 0.7fr 1.3fr;
      gap: 56px;
      padding: 34px;
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      background: linear-gradient(145deg, #fff 0%, #f7f8fa 100%);
      box-shadow: var(--shadow-md);
    }

    .workflow-tabs {
      display: grid;
      align-content: center;
      gap: 10px;
    }

    .workflow-tab {
      display: grid;
      grid-template-columns: 42px 1fr;
      align-items: center;
      gap: 12px;
      width: 100%;
      padding: 14px;
      border: 1px solid transparent;
      border-radius: 13px;
      color: var(--ink-soft);
      background: transparent;
      text-align: left;
      cursor: pointer;
    }

    .workflow-tab strong,
    .workflow-tab small {
      display: block;
    }

    .workflow-tab small {
      margin-top: 2px;
      color: var(--muted);
      font-size: 0.72rem;
    }

    .workflow-tab .step-no {
      display: grid;
      width: 38px;
      height: 38px;
      place-items: center;
      border-radius: 10px;
      color: var(--accent);
      background: var(--accent-soft);
      font-size: 0.75rem;
      font-weight: 850;
    }

    .workflow-tab.active {
      border-color: #fed7bb;
      color: var(--ink);
      background: var(--surface-warm);
    }

    .workflow-tab.active .step-no {
      color: #fff;
      background: var(--brand);
    }

    .workflow-visual {
      position: relative;
      min-height: 430px;
      overflow: hidden;
      border-radius: 22px;
      color: #fff;
      background: var(--ink);
    }

    .workflow-screen {
      display: none;
      min-height: 430px;
      align-content: center;
      padding: 44px;
      animation: screen-in 380ms var(--ease);
    }

    .workflow-screen.active {
      display: grid;
    }

    @keyframes screen-in {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .screen-tag {
      width: fit-content;
      margin-bottom: 18px;
      padding: 6px 9px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 999px;
      color: #fed7bb;
      background: rgba(243, 111, 33, 0.12);
      font-size: 0.67rem;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .workflow-screen h3 {
      max-width: 440px;
      margin-bottom: 12px;
      font-size: clamp(1.7rem, 3vw, 2.6rem);
    }

    .workflow-screen > p {
      max-width: 520px;
      margin-bottom: 28px;
      color: #cbd2df;
    }

    .screen-metrics {
      display: grid;
      max-width: 540px;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .screen-metric {
      padding: 14px;
      border: 1px solid rgba(255, 255, 255, 0.11);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.06);
    }

    .screen-metric strong {
      display: block;
      color: #fff;
      font-size: 1.16rem;
    }

    .screen-metric span {
      color: #aab4c6;
      font-size: 0.68rem;
    }

    .orbit {
      position: absolute;
      right: -90px;
      bottom: -120px;
      width: 340px;
      height: 340px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 50%;
    }

    .orbit::before,
    .orbit::after {
      position: absolute;
      inset: 48px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 50%;
      content: "";
    }

    .orbit::after {
      inset: 100px;
      background: rgba(243, 111, 33, 0.2);
    }

    .benefits {
      padding: 110px 0;
      background: var(--surface-soft);
    }

    .benefit-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .benefit-card {
      padding: 28px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: #fff;
      transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms var(--ease);
    }

    .benefit-card:hover {
      border-color: #f7b58d;
      box-shadow: var(--shadow-md);
      transform: translateY(-4px);
    }

    .benefit-icon {
      display: grid;
      width: 46px;
      height: 46px;
      margin-bottom: 22px;
      place-items: center;
      border-radius: 13px;
      color: var(--brand-dark);
      background: var(--brand-soft);
    }

    .benefit-card:nth-child(2n) .benefit-icon {
      color: var(--accent);
      background: var(--accent-soft);
    }

    .benefit-card p {
      margin-bottom: 0;
      color: var(--muted);
      font-size: 0.91rem;
    }

    .outlet-types {
      padding: 110px 0;
    }

    .type-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .type-card {
      position: relative;
      min-height: 270px;
      overflow: hidden;
      padding: 26px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      color: #fff;
      background: var(--ink);
    }

    .type-card:nth-child(2) {
      background: #2e3b58;
    }

    .type-card:nth-child(3) {
      background: #59311e;
    }

    .type-card:nth-child(4) {
      background: #243c36;
    }

    .type-card::after {
      position: absolute;
      right: -60px;
      bottom: -70px;
      width: 180px;
      height: 180px;
      border: 38px solid rgba(255, 255, 255, 0.07);
      border-radius: 50%;
      content: "";
      transition: transform 500ms var(--ease);
    }

    .type-card:hover::after {
      transform: scale(1.12) rotate(12deg);
    }

    .type-card .type-number {
      display: inline-grid;
      width: 34px;
      height: 34px;
      margin-bottom: 58px;
      place-items: center;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 10px;
      color: #fed7bb;
      font-size: 0.74rem;
      font-weight: 850;
    }

    .type-card h3 {
      position: relative;
      z-index: 1;
      font-size: 1.35rem;
    }

    .type-card p {
      position: relative;
      z-index: 1;
      margin-bottom: 0;
      color: #d0d5dd;
      font-size: 0.84rem;
    }

    .setup {
      padding: 110px 0;
      background: var(--surface-warm);
    }

    .setup-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      counter-reset: setup;
    }

    .setup-step {
      position: relative;
      padding: 28px;
      border-left: 3px solid var(--brand);
      counter-increment: setup;
    }

    .setup-step::before {
      display: block;
      margin-bottom: 25px;
      color: var(--brand-dark);
      content: "0" counter(setup);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.1em;
    }

    .setup-step p {
      margin-bottom: 0;
      color: var(--muted);
    }

    .reliability {
      padding: 110px 0;
      color: #fff;
      background: var(--ink);
    }

    .reliability-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
      gap: 76px;
    }

    .reliability .eyebrow {
      color: #fdb98e;
    }

    .reliability-copy > p {
      color: #b8c1d0;
    }

    .reliability-list {
      display: grid;
      gap: 13px;
      margin-top: 28px;
    }

    .reliability-item {
      display: grid;
      grid-template-columns: 36px 1fr;
      gap: 12px;
      align-items: start;
    }

    .reliability-item .check {
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 10px;
      color: #75e0b7;
      background: rgba(22, 132, 91, 0.18);
    }

    .reliability-item strong,
    .reliability-item span {
      display: block;
    }

    .reliability-item span {
      color: #98a2b3;
      font-size: 0.82rem;
    }

    .sync-map {
      position: relative;
      min-height: 430px;
    }

    .sync-core {
      position: absolute;
      top: 50%;
      left: 50%;
      display: grid;
      width: 116px;
      height: 116px;
      place-items: center;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 50%;
      background: rgba(243, 111, 33, 0.16);
      box-shadow: 0 0 0 34px rgba(243, 111, 33, 0.06), 0 0 0 70px rgba(243, 111, 33, 0.03);
      transform: translate(-50%, -50%);
    }

    .sync-core .brand-mark {
      width: 54px;
      height: 54px;
      border: 1px solid rgba(255, 255, 255, 0.14);
    }

    .sync-node {
      position: absolute;
      display: grid;
      width: 132px;
      min-height: 78px;
      place-content: center;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 14px;
      color: #fff;
      background: #253049;
      text-align: center;
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    }

    .sync-node strong,
    .sync-node span {
      display: block;
    }

    .sync-node strong {
      font-size: 0.82rem;
    }

    .sync-node span {
      color: #98a2b3;
      font-size: 0.65rem;
    }

    .sync-node::after {
      position: absolute;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #75e0b7;
      box-shadow: 0 0 0 5px rgba(117, 224, 183, 0.1);
      content: "";
    }

    .node-pos { top: 12px; left: 20px; }
    .node-pos::after { right: -4px; bottom: 12px; }
    .node-kds { top: 22px; right: 2px; }
    .node-kds::after { bottom: 12px; left: -4px; }
    .node-manager { right: 22px; bottom: 12px; }
    .node-manager::after { top: 12px; left: -4px; }
    .node-guest { bottom: 24px; left: 2px; }
    .node-guest::after { top: 12px; right: -4px; }

    .pricing {
      padding: 110px 0;
      background: #fff;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
      gap: 18px;
    }

    .price-card {
      display: flex;
      min-width: 0;
      flex-direction: column;
      padding: 30px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: #fff;
    }

    .price-card.featured {
      border-color: var(--ink);
      color: #fff;
      background: var(--ink);
      box-shadow: var(--shadow-lg);
      transform: translateY(-10px);
    }

    .plan-badge {
      width: fit-content;
      margin-bottom: 18px;
      padding: 5px 9px;
      border-radius: 999px;
      color: var(--brand-dark);
      background: var(--brand-soft);
      font-size: 0.68rem;
      font-weight: 850;
    }

    .price-name {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 850;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .featured .price-name {
      color: #b8c1d0;
    }

    .price-value {
      margin: 8px 0 4px;
      font-size: 2.5rem;
      font-weight: 900;
      letter-spacing: -0.055em;
    }

    .price-value span {
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 650;
      letter-spacing: 0;
    }

    .featured .price-value span {
      color: #98a2b3;
    }

    .price-summary {
      min-height: 50px;
      margin-bottom: 20px;
      color: var(--muted);
      font-size: 0.85rem;
    }

    .featured .price-summary {
      color: #b8c1d0;
    }

    .price-list {
      display: grid;
      gap: 11px;
      margin: 0 0 28px;
      padding: 22px 0 0;
      border-top: 1px solid var(--line);
      list-style: none;
    }

    .featured .price-list {
      border-color: rgba(255, 255, 255, 0.12);
    }

    .price-list li {
      display: grid;
      grid-template-columns: 18px 1fr;
      align-items: start;
      gap: 8px;
      font-size: 0.85rem;
    }

    .price-list .icon {
      width: 17px;
      color: var(--success);
    }

    .price-card .btn {
      width: 100%;
      margin-top: auto;
    }

    .pricing-note {
      margin: 30px auto 0;
      color: var(--muted);
      font-size: 0.83rem;
      text-align: center;
    }

    .faq {
      padding: 110px 0;
      background: var(--surface-soft);
    }

    .faq-layout {
      display: grid;
      grid-template-columns: 0.72fr 1.28fr;
      gap: 70px;
    }

    .faq-intro {
      position: sticky;
      top: 112px;
      align-self: start;
    }

    .faq-intro p {
      color: var(--muted);
    }

    .faq-list {
      display: grid;
      gap: 10px;
    }

    details {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #fff;
    }

    summary {
      display: flex;
      min-height: 64px;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 18px 20px;
      font-weight: 780;
      list-style: none;
      cursor: pointer;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    summary::after {
      display: grid;
      width: 25px;
      height: 25px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 8px;
      color: var(--accent);
      background: var(--accent-soft);
      content: "+";
      font-size: 1.05rem;
    }

    details[open] summary::after {
      content: "−";
    }

    details p {
      margin: 0;
      padding: 0 20px 20px;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .final-cta {
      padding: 100px 0;
      overflow: hidden;
      color: #fff;
      background: var(--brand);
    }

    .final-cta::before,
    .final-cta::after {
      position: absolute;
      border: 1px solid rgba(255, 255, 255, 0.22);
      border-radius: 50%;
      content: "";
    }

    .final-cta::before {
      top: -210px;
      left: -130px;
      width: 430px;
      height: 430px;
    }

    .final-cta::after {
      right: -160px;
      bottom: -260px;
      width: 520px;
      height: 520px;
    }

    .cta-wrap {
      display: grid;
      position: relative;
      z-index: 1;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 50px;
    }

    .cta-wrap h2 {
      max-width: 760px;
      margin-bottom: 12px;
    }

    .cta-wrap p {
      max-width: 650px;
      margin-bottom: 0;
      color: #fff0e7;
    }

    .cta-actions {
      display: grid;
      gap: 10px;
      min-width: 220px;
    }

    .cta-actions .btn-secondary {
      border-color: rgba(255, 255, 255, 0.65);
      color: #fff;
      background: transparent;
    }

    .site-footer {
      padding: 66px 0 22px;
      color: #d0d5dd;
      background: #101828;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.25fr 0.75fr 0.75fr 1fr;
      gap: 42px;
      padding-bottom: 48px;
    }

    .footer-brand p {
      max-width: 360px;
      margin: 18px 0 20px;
      color: #98a2b3;
      font-size: 0.86rem;
    }

    .site-footer .brand {
      color: #fff;
    }

    .footer-heading {
      margin-bottom: 15px;
      color: #fff;
      font-size: 0.8rem;
      font-weight: 850;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .footer-links {
      display: grid;
      gap: 10px;
    }

    .footer-links a {
      width: fit-content;
      color: #98a2b3;
      font-size: 0.84rem;
      text-decoration: none;
    }

    .footer-links a:hover {
      color: #fff;
    }

    .contact-line {
      margin-bottom: 12px;
      color: #98a2b3;
      font-size: 0.84rem;
    }

    .contact-line a {
      color: #fff;
      text-decoration: none;
    }

    .footer-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding-top: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      color: #667085;
      font-size: 0.76rem;
    }

    .mobile-cta {
      position: fixed;
      right: 12px;
      bottom: 12px;
      left: 12px;
      z-index: 900;
      display: none;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      padding: 8px;
      border: 1px solid var(--line);
      border-radius: 15px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(14px);
    }

    .mobile-cta .btn {
      min-height: 44px;
      padding: 9px 11px;
      font-size: 0.8rem;
    }

    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 600ms var(--ease), transform 600ms var(--ease);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 1050px) {
      .desktop-nav {
        gap: 18px;
      }

      .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero-copy {
        max-width: 760px;
        text-align: center;
        margin-inline: auto;
      }

      .hero-copy > p,
      .hero-actions,
      .hero-assurances {
        justify-content: center;
        margin-inline: auto;
      }

      .product-stage {
        width: min(100%, 720px);
        margin-inline: auto;
      }

      .proof-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .proof-intro {
        grid-column: 1 / -1;
        padding: 0 0 18px;
        text-align: center;
      }

      .proof-item:first-of-type {
        border-left: 0;
      }

      .workflow-stage,
      .reliability-grid {
        grid-template-columns: 1fr;
      }

      .workflow-tabs {
        grid-template-columns: repeat(4, 1fr);
      }

      .workflow-tab {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .workflow-tab .step-no {
        margin-inline: auto;
      }

      .type-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .sync-map {
        width: min(100%, 620px);
        margin-inline: auto;
      }
    }

    @media (max-width: 820px) {
      .desktop-nav,
      .nav-actions .nav-signin,
      .nav-actions .nav-register {
        display: none;
      }

      .menu-toggle {
        display: grid;
      }

      .benefit-grid,
      .pricing-grid {
        grid-template-columns: 1fr;
      }

      .benefit-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .price-card.featured {
        transform: none;
      }

      .setup-grid {
        grid-template-columns: 1fr;
      }

      .setup-step {
        padding-block: 18px;
      }

      .faq-layout {
        grid-template-columns: 1fr;
        gap: 36px;
      }

      .faq-intro {
        position: static;
      }

      .cta-wrap {
        grid-template-columns: 1fr;
      }

      .cta-actions {
        grid-template-columns: 1fr 1fr;
      }

      .footer-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .mobile-cta {
        display: grid;
      }

      .site-footer {
        padding-bottom: 100px;
      }
    }

    @media (max-width: 600px) {
      .container {
        width: min(calc(100% - 28px), var(--max-width));
      }

      .nav-wrap {
        min-height: 66px;
      }

      .brand {
        font-size: 0.92rem;
      }

      .brand-mark {
        width: 33px;
        height: 33px;
      }

      .hero {
        min-height: auto;
        padding: 112px 0 64px;
      }

      .hero-badge {
        font-size: 0.7rem;
      }

      .hero-copy > p {
        font-size: 1rem;
      }

      .hero-actions {
        display: grid;
      }

      .hero-actions .btn {
        width: 100%;
      }

      .hero-assurances {
        align-items: center;
        flex-direction: column;
      }

      .product-stage {
        min-height: 420px;
        margin-top: 20px;
      }

      .dashboard {
        inset: 20px 0 auto;
        transform: none;
      }

      .dash-body {
        min-height: 315px;
        grid-template-columns: 42px 1fr;
      }

      .dash-sidebar {
        padding: 12px 5px;
      }

      .dash-sidebar span {
        width: 29px;
        height: 29px;
      }

      .dash-content {
        padding: 10px;
      }

      .dash-stats {
        grid-template-columns: repeat(2, 1fr);
      }

      .dash-stat:last-child {
        display: none;
      }

      .dash-panels {
        grid-template-columns: 1fr;
      }

      .dash-panel:last-child {
        display: none;
      }

      .dash-panel {
        min-height: 190px;
      }

      .flow-chip {
        padding: 8px 10px;
        font-size: 0.6rem;
      }

      .flow-chip .chip-icon {
        width: 26px;
        height: 26px;
      }

      .chip-kitchen {
        right: 8px;
      }

      .chip-stock {
        right: 0;
        bottom: 20px;
      }

      .chip-receipt {
        bottom: 8px;
        left: 0;
      }

      .proof-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .proof-item {
        padding: 10px 14px;
        border-left: 0;
        text-align: center;
      }

      .workflow,
      .benefits,
      .outlet-types,
      .setup,
      .reliability,
      .pricing,
      .faq {
        padding: 78px 0;
      }

      .section-heading {
        margin-bottom: 34px;
      }

      .workflow-stage {
        gap: 20px;
        padding: 14px;
        border-radius: 22px;
      }

      .workflow-tabs {
        grid-template-columns: repeat(2, 1fr);
      }

      .workflow-tab {
        padding: 10px;
      }

      .workflow-tab small {
        display: none;
      }

      .workflow-visual,
      .workflow-screen {
        min-height: 400px;
      }

      .workflow-screen {
        padding: 26px;
      }

      .screen-metrics {
        grid-template-columns: 1fr;
      }

      .benefit-grid,
      .type-grid {
        grid-template-columns: 1fr;
      }

      .type-card {
        min-height: 240px;
      }

      .sync-map {
        min-height: 500px;
      }

      .sync-node {
        width: 112px;
      }

      .node-pos { top: 0; left: 0; }
      .node-kds { top: 12px; right: 0; }
      .node-manager { right: 0; bottom: 10px; }
      .node-guest { bottom: 0; left: 0; }

      .cta-actions {
        grid-template-columns: 1fr;
      }

      .footer-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .footer-bottom {
        align-items: flex-start;
        flex-direction: column;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }

      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
      }

      .reveal {
        opacity: 1;
        transform: none;
      }
    }
  </style>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "CodeArc RestroSuite",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, Android",
      "description": "Restaurant POS, kitchen display, inventory, billing, loyalty, and reporting platform.",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "999",
        "highPrice": "4999",
        "priceCurrency": "INR",
        "offerCount": "3"
      },
      "provider": {
        "@type": "Organization",
        "name": "CodeArc Tech Labs Private Limited",
        "url": "https://codearc.co.in"
      }
    }
  </script>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="site-header" id="site-header">
    <div class="container nav-wrap">
      <a class="brand" href="#top" aria-label="CodeArc RestroSuite home">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>CodeArc <span class="brand-product">RestroSuite</span></span>
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        <a href="#workflow">How it works</a>
        <a href="#features">Features</a>
        <a href="#reliability">Reliability</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
      </nav>

      <div class="nav-actions">
