 <script src="assets/features-extra.js"></script>
 <script src="src/dashboard/onboarding.js?v=20260619-duestour"></script>
 <script src="assets/features-shell.js?v=20260618-realdata2"></script>
+
+<script>
+/* Fix 1: Sidebar hamburger toggle — mobile/tablet */
+(function () {
+  var btn     = document.getElementById("sidebarToggle");
+  var sidebar = document.querySelector(".sidebar");
+  var overlay = document.getElementById("sidebarOverlay");
+  if (!btn || !sidebar || !overlay) return;
+  function openNav()  {
+    sidebar.classList.add("reveal");
+    overlay.classList.add("active");
+    btn.setAttribute("aria-expanded", "true");
+    btn.innerHTML = '<i class="fa fa-times"></i>';
+  }
+  function closeNav() {
+    sidebar.classList.remove("reveal");
+    overlay.classList.remove("active");
+    btn.setAttribute("aria-expanded", "false");
+    btn.innerHTML = '<i class="fa fa-bars"></i>';
+  }
+  btn.addEventListener("click", function () {
+    sidebar.classList.contains("reveal") ? closeNav() : openNav();
+  });
+  overlay.addEventListener("click", closeNav);
+  document.addEventListener("keydown", function (e) {
+    if (e.key === "Escape") closeNav();
+  });
+  // Auto-close when a nav link is tapped on mobile
+  sidebar.querySelectorAll(".sidebar-link").forEach(function(el) {
+    el.addEventListener("click", function() {
+      if (window.innerWidth < 1025) closeNav();
+    });
+  });
+}());
+</script>
 </body>
